<!-- 统计图表组件 -->
<view class="chart-container" style="height: {{height}}rpx;">
  <!-- ECharts Canvas -->
  <view wx:if="{{!fallback && option}}">
    <ec-canvas
      id="echarts-canvas"
      canvas-id="echarts-canvas"
      ec="{{echartsInstance}}"
    ></ec-canvas>
  </view>

  <!-- 回退：纯文字数据展示 -->
  <view class="fallback-view" wx:if="{{fallback}}">
    <view class="fallback-title">图表数据摘要</view>
    <view class="fallback-list">
      <block wx:if="{{option.xAxis && option.xAxis.type === 'category'}}">
        <!-- 折线图/柱状图：x轴有类目标签 -->
        <view
          class="fallback-item"
          wx:for="{{option.series[0].data}}"
          wx:key="index"
        >
          <view class="fb-name">{{option.xAxis.data[index] || '-'}}</view>
          <view class="fb-value">{{item}} 课时</view>
        </view>
      </block>
      <block wx:elif="{{option.series[0].type === 'pie'}}">
        <!-- 饼图：每项是 {name, value} -->
        <view
          class="fallback-item"
          wx:for="{{option.series[0].data}}"
          wx:key="name"
        >
          <view class="fb-name">{{item.name}}</view>
          <view class="fb-value">{{item.value}} 课时</view>
        </view>
      </block>
      <block wx:else>
        <!-- 其他类型 -->
        <view
          class="fallback-item"
          wx:for="{{option.series[0].data}}"
          wx:key="index"
        >
          <view class="fb-name">第{{index + 1}}项</view>
          <view class="fb-value">{{item.value !== undefined ? item.value : item}}</view>
        </view>
      </block>
    </view>
  </view>

  <!-- 无数据 -->
  <view class="empty-chart" wx:if="{{!option}}">
    <text>暂无图表数据</text>
  </view>
</view>
