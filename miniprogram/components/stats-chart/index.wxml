<!-- 统计图表组件 -->
<view class="chart-container" style="min-height: {{height}}rpx;">

  <!-- 柱状图（折线图替代） -->
  <view class="bar-chart" wx:if="{{isLine && barData.length > 0}}">
    <view class="bar-list">
      <view class="bar-row" wx:for="{{barData}}" wx:key="label">
        <text class="bar-label">{{item.label}}</text>
        <view class="bar-track">
          <view class="bar-fill" style="width: {{item.percent}}%"></view>
        </view>
        <text class="bar-value">{{item.value}}</text>
      </view>
    </view>
  </view>

  <!-- 饼图（列表替代） -->
  <view class="pie-list" wx:if="{{isPie && pieData.length > 0}}">
    <view class="pie-item" wx:for="{{pieData}}" wx:key="name">
      <view class="pie-dot" style="background: {{item.color}}"></view>
      <text class="pie-name">{{item.name}}</text>
      <text class="pie-value">{{item.value}} 课时</text>
    </view>
  </view>

  <!-- 无数据 -->
  <view class="empty-chart" wx:if="{{!isLine && !isPie}}">
    <text>暂无图表数据</text>
  </view>

</view>
