/**
 * 统计图表组件样式
 */
.chart-container {
  width: 100%;
  position: relative;
  overflow: hidden;
}

/* 柱状图 */
.bar-chart {
  padding: var(--spacing-sm) 0;
}

.bar-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.bar-row {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: var(--spacing-sm);
}

.bar-label {
  font-size: var(--font-size-xs);
  color: var(--color-text-secondary);
  width: 100rpx;
  text-align: right;
  flex-shrink: 0;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.bar-track {
  flex: 1;
  height: 24rpx;
  background: var(--color-bg);
  border-radius: 12rpx;
  overflow: hidden;
}

.bar-fill {
  height: 100%;
  background: linear-gradient(to right, var(--color-primary), var(--color-success));
  border-radius: 12rpx;
  transition: width 0.3s ease;
  min-width: 4rpx;
}

.bar-value {
  font-size: var(--font-size-xs);
  color: var(--color-text-primary);
  font-weight: 600;
  width: 60rpx;
  text-align: left;
  flex-shrink: 0;
}

/* 饼图（列表替代） */
.pie-list {
  display: flex;
  flex-direction: column;
  gap: var(--spacing-sm);
  padding: var(--spacing-sm) 0;
}

.pie-item {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: var(--spacing-sm);
  padding: var(--spacing-xs) 0;
}

.pie-dot {
  width: 20rpx;
  height: 20rpx;
  border-radius: 10rpx;
  flex-shrink: 0;
}

.pie-name {
  font-size: var(--font-size-sm);
  color: var(--color-text-primary);
  flex: 1;
}

.pie-value {
  font-size: var(--font-size-sm);
  color: var(--color-text-secondary);
  font-weight: 500;
}

.empty-chart {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 100%;
  color: var(--color-text-secondary);
  font-size: var(--font-size-sm);
}
