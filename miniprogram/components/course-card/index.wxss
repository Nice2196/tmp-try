/**
 * 课程卡片组件样式
 * 设计签名：左侧色带 + 环形进度
 */

.card-accent {
  background: var(--color-card);
  margin: var(--spacing-sm) var(--spacing-md);
  padding: var(--spacing-md);
  padding-left: calc(var(--spacing-md) + 6rpx);
  border-radius: var(--radius-md);
  border-left: 6rpx solid var(--color-primary);
  box-shadow: var(--shadow-card);
  transition: transform 0.15s var(--ease-out);
}

.card-accent:active {
  transform: scale(0.985);
}

/* 状态色带 */
.card-status-active {
  border-left-color: var(--color-success);
}

.card-status-paused {
  border-left-color: var(--color-warning);
}

.card-status-completed {
  border-left-color: var(--color-primary);
}

.card-status-expired {
  border-left-color: var(--color-expired);
}

/* ==================== 卡片主体 ==================== */
.card-main {
  display: flex;
  flex-direction: row;
  align-items: flex-start;
  justify-content: space-between;
}

.card-info {
  flex: 1;
  min-width: 0;
  margin-right: var(--spacing-md);
}

.card-name-row {
  display: flex;
  flex-direction: row;
  align-items: center;
  margin-bottom: 8rpx;
}

.card-name {
  font-size: var(--font-size-md);
  font-weight: 600;
  color: var(--color-text-primary);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  flex: 1;
}

/* 标签 */
.tag {
  font-size: var(--font-size-xs);
  padding: 2rpx 12rpx;
  border-radius: 6rpx;
  margin-left: var(--spacing-xs);
  flex-shrink: 0;
  font-weight: 500;
}

.tag-active {
  color: var(--color-success);
  background: var(--color-success-light);
}

.tag-paused {
  color: var(--color-warning);
  background: var(--color-warning-light);
}

.tag-completed {
  color: var(--color-primary);
  background: var(--color-pending-light);
}

.tag-expired {
  color: var(--color-expired);
  background: var(--color-expired-light);
}

/* 元信息 */
.card-meta {
  display: flex;
  flex-direction: row;
  align-items: center;
}

.meta-item {
  font-size: var(--font-size-xs);
  color: var(--color-text-secondary);
}

.meta-dot {
  margin: 0 8rpx;
  color: var(--color-text-disabled);
  font-size: var(--font-size-xs);
}

/* ==================== 环形进度 ==================== */
.card-progress-ring {
  position: relative;
  width: 100rpx;
  height: 100rpx;
  flex-shrink: 0;
}

.ring-bg {
  position: absolute;
  top: 0;
  left: 0;
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  border: 8rpx solid var(--color-border);
  box-sizing: border-box;
}

.ring-fill {
  position: absolute;
  top: 8rpx;
  left: 8rpx;
  width: calc(100rpx - 16rpx);
  height: calc(100rpx - 16rpx);
  border-radius: 50%;
  box-sizing: border-box;
  transition: background 0.6s var(--ease-out);
  background: var(--color-border);
}

.ring-center {
  position: absolute;
  top: 0;
  left: 0;
  width: 100rpx;
  height: 100rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.ring-value {
  font-size: var(--font-size-lg);
  font-weight: 700;
  color: var(--color-text-primary);
  line-height: 1.1;
}

.ring-label {
  font-size: 20rpx;
  color: var(--color-text-helper);
  margin-top: 2rpx;
}

/* ==================== 底部进度条 ==================== */
.card-bottom {
  margin-top: var(--spacing-sm);
}

.hours-bar {
  height: 6rpx;
  background: var(--color-border);
  border-radius: 3rpx;
  overflow: hidden;
  margin-bottom: 6rpx;
}

.hours-fill {
  height: 100%;
  background: var(--color-success);
  border-radius: 3rpx;
  transition: width 0.5s var(--ease-out);
}

.card-status-expired .hours-fill {
  background: var(--color-expired);
}

.card-status-paused .hours-fill {
  background: var(--color-warning);
}

.hours-info {
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  align-items: center;
}

.hours-text {
  font-size: var(--font-size-xs);
  color: var(--color-text-secondary);
}

.hours-percent {
  font-size: var(--font-size-xs);
  font-weight: 600;
  color: var(--color-success);
}

.hours-warn {
  color: var(--color-expired);
}

.card-status-paused .hours-percent {
  color: var(--color-warning);
}

.card-status-expired .hours-percent {
  color: var(--color-expired);
}

/* ==================== 过期提醒 ==================== */
.card-expiry {
  display: flex;
  flex-direction: row;
  align-items: center;
  margin-top: var(--spacing-sm);
  padding-top: var(--spacing-sm);
  border-top: 1rpx solid var(--color-border);
}

.expiry-dot {
  width: 8rpx;
  height: 8rpx;
  border-radius: 50%;
  background: var(--color-warning);
  margin-right: var(--spacing-xs);
  flex-shrink: 0;
}

.expiry-text {
  font-size: var(--font-size-xs);
  color: var(--color-warning);
  font-weight: 500;
}
