/**
 * 日历网格组件样式
 */
.calendar-grid {
  display: flex;
  flex-direction: row;
  flex-wrap: wrap;
  padding: 4rpx;
  background: var(--color-card);
}

.cell-wrapper {
  width: calc(100% / 7);
  /* 维持正方形 */
  aspect-ratio: 1;
  box-sizing: border-box;
  padding: 2rpx;
}

.cell {
  width: 100%;
  height: 100%;
  border-radius: var(--radius-sm);
  display: flex;
  align-items: center;
  justify-content: center;
}

.cell-other-month {
  opacity: 0.3;
}

.cell-inner {
  width: 100%;
  height: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  border-radius: var(--radius-sm);
  position: relative;
}

.cell-inner.today {
  background: rgba(24, 144, 255, 0.08);
  border: 2rpx solid var(--color-primary);
}

/* ==================== 状态颜色边框 ==================== */
.cell-inner.today[data-status="completed"] {
  background: rgba(82, 196, 26, 0.08);
  border-color: var(--color-success);
}

.cell-inner.today[data-status="expired"] {
  background: rgba(255, 77, 79, 0.08);
  border-color: var(--color-expired);
}

.cell-day {
  font-size: 26rpx;
  color: var(--color-text-primary);
  font-weight: 500;
}

.today-text {
  font-weight: 700;
  color: var(--color-primary);
}

/* 课程标记 */
.cell-dots {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-top: 2rpx;
}

.dot-row {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 2rpx;
}

.dot {
  width: 10rpx;
  height: 10rpx;
  border-radius: var(--radius-round);
  flex-shrink: 0;
}

.dot-completed {
  background: var(--color-success);
}

.dot-pending {
  background: var(--color-pending);
}

.dot-expired {
  background: var(--color-expired);
}

.cell-count {
  font-size: 16rpx;
  color: var(--color-text-secondary);
  line-height: 1;
  margin-left: 2rpx;
}

.cell-deduct-type {
  font-size: 14rpx;
  color: var(--color-text-secondary);
  line-height: 1;
  margin-top: 2rpx;
}
