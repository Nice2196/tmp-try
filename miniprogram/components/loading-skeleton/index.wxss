/**
 * 骨架屏组件样式
 */
.skeleton-container {
  padding: var(--spacing-md);
}

/* 动画 */
.skeleton-animate {
  animation: skeleton-blink 1.5s ease-in-out infinite;
}

@keyframes skeleton-blink {
  0% { opacity: 0.3; }
  50% { opacity: 0.6; }
  100% { opacity: 0.3; }
}

/* 通用骨架条 */
.sk-line {
  height: 28rpx;
  background: #E8E8E8;
  border-radius: 6rpx;
  margin-bottom: var(--spacing-sm);
}

.sk-line-title {
  width: 60%;
  height: 40rpx;
  margin-bottom: var(--spacing-md);
}

.sk-line-long { width: 100%; }
.sk-line-mid { width: 70%; }
.sk-line-short { width: 40%; }

.sk-bar {
  height: 12rpx;
  background: #E8E8E8;
  border-radius: 6rpx;
  margin-bottom: var(--spacing-sm);
}

/* Card 模式 */
.sk-card {
  background: var(--color-card);
  border-radius: var(--radius-md);
  padding: var(--spacing-md);
  margin-bottom: var(--spacing-sm);
}

/* List 模式 */
.sk-list-item {
  display: flex;
  flex-direction: row;
  align-items: center;
  padding: var(--spacing-sm) 0;
  margin-bottom: var(--spacing-sm);
}

.sk-avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: var(--radius-round);
  background: #E8E8E8;
  margin-right: var(--spacing-md);
  flex-shrink: 0;
}

.sk-list-content {
  flex: 1;
}

/* Detail 模式 */
.sk-detail {
  background: var(--color-card);
  border-radius: var(--radius-md);
  padding: var(--spacing-lg);
}
