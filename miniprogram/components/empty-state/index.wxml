<!-- 空状态组件 -->
<view class="empty-container">
  <text class="empty-icon">{{icon}}</text>
  <text class="empty-text">{{text}}</text>
  <text class="empty-sub" wx:if="{{subText}}">{{subText}}</text>
  <view class="empty-action" wx:if="{{actionText}}" bindtap="onAction">
    <text>{{actionText}}</text>
  </view>
</view>
