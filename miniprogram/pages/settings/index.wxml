<!--
  设置页
  设计语言：「墨蓝 · 纸白」
-->
<view class="page-container">

  <!-- ==================== 用户信息 ==================== -->
  <view class="section-card">
    <text class="section-label">用户信息</text>

    <view class="setting-item user-profile">
      <button
        class="avatar-btn"
        open-type="chooseAvatar"
        bindchooseavatar="onChooseAvatar"
      >
        <image
          class="user-avatar"
          src="{{avatarUrl || '/images/default-avatar.png'}}"
          mode="aspectFill"
          wx:if="{{avatarUrl}}"
        />
        <view class="user-avatar-placeholder" wx:else>
          <text class="avatar-icon">👤</text>
        </view>
      </button>
      <view class="si-left">
        <text class="si-label">{{nickname || '微信用户'}}</text>
        <text class="si-hint">点击头像更换，下方输入昵称</text>
      </view>
    </view>

    <view class="setting-item">
      <view class="si-left">
        <text class="si-label">昵称</text>
      </view>
      <input
        class="si-input si-input-wide"
        type="nickname"
        placeholder="请输入昵称"
        value="{{nickname}}"
        bindblur="onNicknameBlur"
      />
    </view>

    <view class="setting-item" bindtap="onCopyOpenid" wx:if="{{openid}}">
      <view class="si-left">
        <text class="si-label">用户ID</text>
        <text class="si-hint">{{nickname || openid}}</text>
      </view>
      <text class="si-action">复制</text>
    </view>
  </view>

  <!-- ==================== 系统设置 ==================== -->
  <view class="section-card">
    <text class="section-label">系统设置</text>

    <view class="setting-item">
      <view class="si-left">
        <text class="si-label">低课时预警阈值</text>
        <text class="si-hint">剩余课时低于该值时提醒</text>
      </view>
      <view class="si-input-group">
        <input
          class="si-input si-input-sm"
          type="number"
          value="{{defaultLowHoursThreshold}}"
          bindinput="onThresholdInput"
        />
        <text class="si-unit">课时</text>
      </view>
    </view>

    <view class="setting-item" bindtap="onViewAuditLog">
      <view class="si-left">
        <text class="si-label">操作日志</text>
        <text class="si-hint">查看所有操作记录</text>
      </view>
      <text class="si-arrow">›</text>
    </view>
  </view>

  <!-- ==================== 缓存管理 ==================== -->
  <view class="section-card">
    <text class="section-label">缓存管理</text>
    <view class="setting-item" bindtap="onClearCache">
      <view class="si-left">
        <text class="si-label">清除缓存</text>
        <text class="si-hint">清除本地存储数据</text>
      </view>
      <text class="si-action">清除</text>
    </view>
  </view>

  <!-- ==================== 关于 ==================== -->
  <view class="section-card">
    <text class="section-label">关于</text>
    <view class="about-row">
      <text class="about-label">版本</text>
      <text class="about-value">v{{version}}</text>
    </view>
    <view class="about-row">
      <text class="about-label">技术栈</text>
      <text class="about-value">微信原生 + 云开发</text>
    </view>
    <view class="about-row">
      <text class="about-label">数据库</text>
      <text class="about-value">云数据库（文档型）</text>
    </view>
  </view>

  <!-- ==================== 使用说明 ==================== -->
  <view class="section-card">
    <text class="section-label">使用说明</text>
    <view class="help-list">
      <view class="help-item">
        <text class="help-num">1</text>
        <text class="help-text">创建课程后，设置固定排课即可启用自动消课</text>
      </view>
      <view class="help-item">
        <text class="help-num">2</text>
        <text class="help-text">自动消课每10分钟检查一次，在日历页查看状态</text>
      </view>
      <view class="help-item">
        <text class="help-num">3</text>
        <text class="help-text">手动消课适合临时上课场景</text>
      </view>
      <view class="help-item">
        <text class="help-num">4</text>
        <text class="help-text">所有操作均有审计日志，在「系统设置 → 操作日志」中查看</text>
      </view>
    </view>
  </view>

  <!-- 底部安全距离 -->
  <view class="safe-bottom"></view>

</view>
