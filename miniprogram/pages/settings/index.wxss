/**
 * 设置页样式
 */
.page-container {
  min-height: 100vh;
  background-color: var(--color-bg);
  padding: var(--spacing-md);
}

.card {
  background: var(--color-card);
  border-radius: var(--radius-md);
  padding: var(--spacing-lg);
  box-shadow: var(--shadow-card);
}

.mt-md {
  margin-top: var(--spacing-md);
}

.card-title {
  font-size: var(--font-size-sm);
  font-weight: 600;
  color: var(--color-text-secondary);
  margin-bottom: var(--spacing-sm);
}

.setting-item {
  display: flex;
  flex-direction: row;
  align-items: center;
  padding: var(--spacing-md) 0;
  border-bottom: 1rpx solid var(--color-border);
  gap: var(--spacing-md);
}

.setting-item:last-child {
  border-bottom: none;
}

.setting-item:active {
  background: var(--color-bg);
  margin: 0 calc(-1 * var(--spacing-lg));
  padding-left: var(--spacing-lg);
  padding-right: var(--spacing-lg);
}

.si-left {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.si-label {
  font-size: var(--font-size-md);
  color: var(--color-text-primary);
  flex-shrink: 0;
  margin-right: var(--spacing-md);
}

.si-value {
  font-size: var(--font-size-xs);
  color: var(--color-text-secondary);
  margin-top: 4rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  min-width: 0;
}

.si-action {
  font-size: var(--font-size-sm);
  color: var(--color-primary);
  flex-shrink: 0;
}

.si-arrow {
  font-size: var(--font-size-xl);
  color: var(--color-text-secondary);
  flex-shrink: 0;
}

.si-input {
  width: 80rpx;
  height: 60rpx;
  text-align: center;
  background: var(--color-bg);
  border-radius: var(--radius-sm);
  border: 1rpx solid var(--color-border);
  font-size: var(--font-size-md);
  color: var(--color-text-primary);
}

.si-unit {
  font-size: var(--font-size-xs);
  color: var(--color-text-secondary);
  margin-left: var(--spacing-xs);
}

/* 帮助文本 */
/* 用户头像（Bug 11 修复） */
.user-profile {
  padding: var(--spacing-md) 0;
}

.avatar-btn {
  padding: 0;
  margin: 0;
  background: transparent;
  border: none;
  line-height: 0;
  flex-shrink: 0;
  margin-right: var(--spacing-md);
}

.avatar-btn::after {
  border: none;
}

.user-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: var(--radius-round);
  flex-shrink: 0;
  display: block;
}

.user-avatar-placeholder {
  width: 80rpx;
  height: 80rpx;
  border-radius: var(--radius-round);
  background: var(--color-bg);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  flex-shrink: 0;
}

.si-input-wide {
  width: 260rpx;
  height: 60rpx;
  text-align: left;
  padding: 0 var(--spacing-sm);
  background: var(--color-bg);
  border-radius: var(--radius-sm);
  border: 1rpx solid var(--color-border);
  font-size: var(--font-size-md);
  color: var(--color-text-primary);
}

/* 帮助文本 */
.help-text {
  display: flex;
  flex-direction: column;
  gap: var(--spacing-xs);
}

.help-text text {
  font-size: var(--font-size-sm);
  color: var(--color-text-secondary);
  line-height: 1.6;
}

/* 关于栏 - 独立样式，解决间距问题 */
.about-item {
  display: flex;
  flex-direction: row;
  align-items: center;
  padding: var(--spacing-md) 0;
  border-bottom: 1rpx solid var(--color-border);
}

.about-item:last-child {
  border-bottom: none;
}

.about-label {
  font-size: var(--font-size-md);
  color: var(--color-text-primary);
  width: 160rpx;
  flex-shrink: 0;
}

.about-value {
  font-size: var(--font-size-sm);
  color: var(--color-text-secondary);
  flex: 1;
}

/* 用户资料行 - 防止溢出 */
.user-profile .si-left {
  min-width: 0;
  overflow: hidden;
}

.user-profile .si-label {
  font-size: var(--font-size-lg);
  font-weight: 600;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  max-width: 400rpx;
}

.safe-bottom {
  height: 80rpx;
}
