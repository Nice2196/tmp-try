/**
 * 操作日志页样式
 * 设计语言：「墨蓝 · 纸白」
 */

.page-container {
  min-height: 100vh;
  background-color: var(--color-bg);
}

/* ==================== 筛选栏 ==================== */
.filter-bar {
  background: var(--color-card);
  padding: var(--spacing-sm) var(--spacing-lg);
  border-bottom: 1rpx solid var(--color-border);
}

.filter-summary {
  display: flex;
  flex-direction: row;
  align-items: center;
  font-size: var(--font-size-sm);
  color: var(--color-text-secondary);
}

.filter-icon {
  margin-right: var(--spacing-xs);
  font-size: var(--font-size-xs);
}

.filter-count {
  font-size: var(--font-size-xs);
  color: var(--color-text-helper);
  margin-left: auto;
}

/* 筛选面板 */
.filter-panel {
  background: var(--color-card);
  padding: var(--spacing-md) var(--spacing-lg);
  border-bottom: 1rpx solid var(--color-border);
}

.form-group {
  margin-bottom: var(--spacing-sm);
}

.form-label {
  font-size: var(--font-size-xs);
  color: var(--color-text-helper);
  margin-bottom: 4rpx;
  font-weight: 500;
}

.form-picker {
  width: 100%;
  height: 72rpx;
  padding: 0 var(--spacing-sm);
  background: var(--color-bg);
  border-radius: var(--radius-sm);
  font-size: var(--font-size-sm);
  color: var(--color-text-primary);
  border: 2rpx solid var(--color-border);
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.picker-arrow {
  font-size: var(--font-size-lg);
  color: var(--color-text-disabled);
}

.filter-actions {
  display: flex;
  flex-direction: row;
  gap: var(--spacing-sm);
  margin-top: var(--spacing-sm);
}

.btn-filter {
  flex: 1;
  height: 72rpx;
  border-radius: var(--radius-md);
  font-size: var(--font-size-sm);
  font-weight: 500;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
  transition: all 0.15s var(--ease-out);
}

.btn-filter:active {
  transform: scale(0.97);
}

.btn-reset {
  background: var(--color-bg);
  color: var(--color-text-secondary);
}

.btn-apply {
  background: var(--color-primary);
  color: #FFFFFF;
}

/* ==================== 日志列表 ==================== */
.log-list {
  padding: var(--spacing-sm) 0;
}

.log-item {
  background: var(--color-card);
  margin: var(--spacing-xs) var(--spacing-md);
  padding: var(--spacing-sm) var(--spacing-md);
  border-radius: var(--radius-md);
  box-shadow: var(--shadow-sm);
  border-left: 4rpx solid var(--color-primary-soft);
}

.log-item:active {
  opacity: 0.8;
}

/* 第一行：标签 + 时间 */
.log-row-top {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  margin-bottom: var(--spacing-xs);
}

.log-tags {
  display: flex;
  flex-direction: row;
  align-items: center;
  flex-shrink: 0;
}

.log-action-tag {
  font-size: 22rpx;
  padding: 4rpx 12rpx;
  background: var(--color-primary-light);
  border-radius: 6rpx;
  color: var(--color-primary);
  font-weight: 600;
}

.log-trigger-tag {
  font-size: 20rpx;
  padding: 2rpx 10rpx;
  border-radius: 6rpx;
  margin-left: var(--spacing-xs);
  font-weight: 500;
}

.log-trigger-tag.manual {
  color: #7C3AED;
  background: #EDE9FE;
}

.log-trigger-tag.auto_scheduler {
  color: var(--color-primary);
  background: var(--color-pending-light);
}

.log-time {
  font-size: var(--font-size-xs);
  color: var(--color-text-helper);
  flex-shrink: 0;
  margin-left: var(--spacing-sm);
}

/* 第二行：课程名 */
.log-course {
  font-size: var(--font-size-sm);
  color: var(--color-text-primary);
  font-weight: 500;
  margin-bottom: 4rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* 第三行：操作详情 */
.log-detail {
  font-size: var(--font-size-xs);
  color: var(--color-text-secondary);
  line-height: 1.5;
  margin-bottom: 4rpx;
}

/* 第四行：操作结果 */
.log-result {
  font-size: 20rpx;
  padding: 2rpx 10rpx;
  border-radius: 6rpx;
  display: inline-block;
  font-weight: 500;
}

.log-result.result-default {
  color: var(--color-text-secondary);
  background: var(--color-bg);
}

.log-result.result-success {
  color: var(--color-success);
  background: var(--color-success-light);
}

.log-result.result-danger {
  color: var(--color-expired);
  background: var(--color-expired-light);
}

/* 加载更多 */
.load-more {
  text-align: center;
  padding: var(--spacing-lg);
  font-size: var(--font-size-sm);
  color: var(--color-text-helper);
}

.loading-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: var(--spacing-2xl);
}

.loading-text {
  color: var(--color-text-helper);
  font-size: var(--font-size-sm);
}
