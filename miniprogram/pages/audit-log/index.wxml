<!-- 操作日志页 -->
<view class="page-container" wx:if="{{!loading}}">

  <!-- ==================== 筛选栏 ==================== -->
  <view class="filter-bar">
    <view class="filter-summary" bindtap="onToggleFilter">
      <text class="filter-icon">{{showFilter ? '▲' : '▼'}}</text>
      <text>{{filterAction ? (actionTypeLabel || '筛选') : '筛选'}}</text>
      <text class="filter-count">共 {{total}} 条</text>
    </view>
  </view>

  <!-- 筛选面板 -->
  <view class="filter-panel" wx:if="{{showFilter}}">
    <view class="form-group">
      <view class="form-label">操作类型</view>
      <picker
        range="{{actionOptions}}"
        range-key="label"
        bindchange="onActionTypeChange"
      >
        <view class="form-picker">
          {{actionTypeLabel || '全部操作'}}
          <text class="picker-arrow">›</text>
        </view>
      </picker>
    </view>

    <view class="form-group">
      <view class="form-label">开始日期</view>
      <picker mode="date" value="{{filterStartDate}}" bindchange="onStartDateChange">
        <view class="form-picker">
          {{filterStartDate || '不限'}}
          <text class="picker-arrow">›</text>
        </view>
      </picker>
    </view>

    <view class="form-group">
      <view class="form-label">结束日期</view>
      <picker mode="date" value="{{filterEndDate}}" bindchange="onEndDateChange">
        <view class="form-picker">
          {{filterEndDate || '不限'}}
          <text class="picker-arrow">›</text>
        </view>
      </picker>
    </view>

    <view class="filter-actions">
      <button class="btn-filter btn-reset" bindtap="onResetFilter">重置</button>
      <button class="btn-filter btn-apply" bindtap="onApplyFilter">应用</button>
    </view>
  </view>

  <!-- ==================== 日志列表 ==================== -->
  <view class="log-list" wx:if="{{logs.length > 0}}">
    <view
      class="log-item"
      wx:for="{{logs}}"
      wx:key="_id"
      data-course-id="{{item.courseId}}"
      bindtap="onLogTap"
    >
      <!-- 第一行：标签 + 时间 -->
      <view class="log-row-top">
        <view class="log-tags">
          <view class="log-action-tag">{{item.actionTypeLabel}}</view>
          <view class="log-trigger-tag {{item.trigger}}">{{item.triggerLabel}}</view>
        </view>
        <view class="log-time">{{item.displayTime}}</view>
      </view>

      <!-- 第二行：课程名 -->
      <view class="log-course" wx:if="{{item.courseName}}">{{item.courseName}}</view>

      <!-- 第三行：操作详情 -->
      <view class="log-detail" wx:if="{{item.detailText}}">{{item.detailText}}</view>

      <!-- 第四行：操作结果 -->
      <view class="log-result {{item.resultClass}}" wx:if="{{item.resultText}}">{{item.resultText}}</view>
    </view>
  </view>

  <!-- 空状态 -->
  <empty-state
    wx:else
    icon="📝"
    text="暂无操作日志"
    subText="系统操作会自动记录在此"
  />

  <!-- 加载更多 -->
  <view class="load-more" wx:if="{{hasMore && logs.length > 0}}">
    <text wx:if="{{loadingMore}}">加载中...</text>
    <text wx:else bindtap="loadMore">加载更多</text>
  </view>

</view>

<!-- 加载中 -->
<view class="loading-container" wx:if="{{loading}}">
  <text class="loading-text">加载中...</text>
</view>
