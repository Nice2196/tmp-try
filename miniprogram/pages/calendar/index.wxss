/**
 * 日历看板页样式
 */
.page-container {
  min-height: 100vh;
  background: var(--color-card);
}

/* 月份导航 */
.month-nav {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  padding: var(--spacing-md) var(--spacing-lg);
  background: var(--color-card);
}

.nav-arrow {
  width: 72rpx;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  color: var(--color-primary);
  font-weight: 300;
  border-radius: var(--radius-round);
}

.nav-arrow:active {
  background: var(--color-primary-light);
}

.nav-title {
  font-size: var(--font-size-lg);
  font-weight: 600;
  color: var(--color-text-primary);
}

/* 星期标题 */
.weekday-row {
  display: flex;
  flex-direction: row;
  padding: var(--spacing-sm) var(--spacing-md);
  background: var(--color-bg);
  border-bottom: 1rpx solid var(--color-border);
}

.weekday-col {
  flex: 1;
  text-align: center;
}

.weekday-text {
  font-size: var(--font-size-xs);
  color: var(--color-text-secondary);
}

.weekday-col:first-child .weekday-text,
.weekday-col:last-child .weekday-text {
  color: var(--color-expired);
}

/* 加载 */
.loading-container {
  padding: var(--spacing-xl);
  text-align: center;
}

.loading-text {
  color: var(--color-text-secondary);
  font-size: var(--font-size-sm);
}

/* ==================== 弹窗 ==================== */
.popup-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.45);
  z-index: 100;
  display: flex;
  align-items: flex-end;
  justify-content: center;
}

.popup-content {
  background: var(--color-card);
  border-radius: var(--radius-lg) var(--radius-lg) 0 0;
  width: 100%;
  max-height: 60vh;
  overflow-y: auto;
}

.popup-header {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  padding: var(--spacing-md) var(--spacing-lg);
  border-bottom: 1rpx solid var(--color-border);
}

.popup-title {
  font-size: var(--font-size-lg);
  font-weight: 600;
}

.popup-close {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: var(--font-size-lg);
  color: var(--color-text-secondary);
}

.popup-body {
  padding: var(--spacing-md);
}

/* 汇总信息 */
.lesson-summary {
  padding-bottom: var(--spacing-sm);
  margin-bottom: var(--spacing-sm);
  border-bottom: 1rpx solid var(--color-border);
}

.summary-text {
  font-size: var(--font-size-xs);
  color: var(--color-text-secondary);
}

/* 课程卡片（新设计） */
.lesson-card {
  background: var(--color-bg);
  border-radius: var(--radius-md);
  padding: var(--spacing-md);
  margin-bottom: var(--spacing-sm);
}

.lesson-card:active {
  opacity: 0.8;
}

.lc-header {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  margin-bottom: var(--spacing-xs);
}

.lc-status-badge {
  font-size: var(--font-size-xs);
  padding: 2rpx 16rpx;
  border-radius: var(--radius-round);
}

.lc-status-badge.completed {
  color: var(--color-success);
  background: rgba(82, 196, 26, 0.1);
}

.lc-status-badge.pending {
  color: var(--color-primary);
  background: rgba(24, 144, 255, 0.1);
}

.lc-status-badge.expired {
  color: var(--color-expired);
  background: rgba(255, 77, 79, 0.1);
}

.lc-hours {
  font-size: var(--font-size-sm);
  font-weight: 700;
  color: var(--color-expired);
}

.lc-time-tag {
  font-size: var(--font-size-xs);
  color: var(--color-text-secondary);
}

.lc-body {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
  margin-bottom: var(--spacing-xs);
}

.lc-course-name {
  font-size: var(--font-size-lg);
  font-weight: 600;
  color: var(--color-text-primary);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.lc-time {
  font-size: var(--font-size-xs);
  color: var(--color-text-secondary);
}

.lc-actions {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: var(--spacing-sm);
  margin-top: var(--spacing-xs);
  padding-top: var(--spacing-xs);
  border-top: 1rpx solid var(--color-border);
}

.lc-btn {
  font-size: var(--font-size-xs);
  padding: 6rpx 20rpx;
  border-radius: var(--radius-sm);
}

.lc-btn-edit {
  color: var(--color-primary);
  background: rgba(24, 144, 255, 0.1);
}

.lc-btn-edit:active {
  opacity: 0.7;
}

.lc-btn-delete {
  color: var(--color-expired);
  background: rgba(255, 77, 79, 0.1);
}

.lc-btn-delete:active {
  opacity: 0.7;
}

.lesson-item {
  display: flex;
  flex-direction: row;
  align-items: center;
  padding: var(--spacing-md) 0;
  border-bottom: 1rpx solid var(--color-border);
}

.lesson-item:active {
  background: var(--color-bg);
  border-radius: var(--radius-sm);
}

.lesson-status-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: var(--radius-round);
  margin-right: var(--spacing-md);
  flex-shrink: 0;
}

.lesson-status-dot.completed {
  background: var(--color-success);
}

.lesson-status-dot.pending {
  background: var(--color-pending);
}

.lesson-status-dot.expired {
  background: var(--color-expired);
}

.lesson-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.lesson-name {
  font-size: var(--font-size-md);
  color: var(--color-text-primary);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  max-width: 360rpx;
}

.lesson-time {
  font-size: var(--font-size-xs);
  color: var(--color-text-secondary);
  margin-top: 4rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.lesson-arrow {
  font-size: 32rpx;
  color: var(--color-text-secondary);
  margin-left: var(--spacing-sm);
}

.lesson-btns {
  display: flex;
  flex-direction: row;
  align-items: center;
  margin-left: var(--spacing-sm);
  flex-shrink: 0;
}

.lesson-btn {
  font-size: var(--font-size-xs);
  padding: 6rpx 16rpx;
  border-radius: var(--radius-sm);
  margin-left: 8rpx;
}

.lesson-btn-edit {
  color: var(--color-primary);
  background: rgba(24, 144, 255, 0.1);
}

.lesson-btn-edit:active {
  opacity: 0.7;
}

.lesson-btn-delete {
  color: var(--color-expired);
  background: rgba(255, 77, 79, 0.1);
}

.lesson-btn-delete:active {
  opacity: 0.7;
}

.lesson-action {
  margin-left: var(--spacing-sm);
  flex-shrink: 0;
}

.btn-deduct-small {
  font-size: var(--font-size-xs);
  padding: 8rpx 24rpx;
  background: var(--color-primary);
  color: #fff;
  border-radius: var(--radius-sm);
  border: none;
  line-height: 1.5;
}

.btn-deduct-small:active {
  opacity: 0.8;
}

.empty-lesson {
  text-align: center;
  padding: var(--spacing-xl);
  color: var(--color-text-secondary);
  font-size: var(--font-size-sm);
}

/* 弹窗底部操作栏 */
.popup-footer {
  padding: var(--spacing-md);
  border-top: 1rpx solid var(--color-border);
}

.btn-add-lesson {
  width: 100%;
  background: var(--color-primary);
  color: #fff;
  border-radius: var(--radius-sm);
  font-size: var(--font-size-md);
  padding: var(--spacing-sm) 0;
  border: none;
}

.btn-add-lesson:active {
  opacity: 0.8;
}
