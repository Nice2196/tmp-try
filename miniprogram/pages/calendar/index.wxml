<!-- 日历看板页 -->
<view class="page-container">

  <!-- ==================== 月份切换导航 ==================== -->
  <view class="month-nav">
    <view class="nav-arrow" bindtap="onPrevMonth">‹</view>
    <view class="nav-title">{{year}}年 {{month}}月</view>
    <view class="nav-arrow" bindtap="onNextMonth">›</view>
  </view>

  <!-- ==================== 星期标题行 ==================== -->
  <view class="weekday-row">
    <view class="weekday-col" wx:for="{{['日','一','二','三','四','五','六']}}" wx:key="*this">
      <text class="weekday-text">{{item}}</text>
    </view>
  </view>

  <!-- ==================== 日历组件 ==================== -->
  <view class="calendar-wrapper" wx:if="{{!loading && days.length > 0}}">
    <calendar-view
      year="{{year}}"
      month="{{month}}"
      days="{{days}}"
      bind:daytap="onDayTap"
    />
  </view>

  <!-- 空状态 -->
  <empty-state
    wx:if="{{!loading && days.length === 0}}"
    icon="📅"
    text="暂无排课数据"
    subText="添加课程并设置固定上课时间"
  />

  <!-- 加载中 -->
  <view class="loading-container" wx:if="{{loading}}">
    <text class="loading-text">加载中...</text>
  </view>

  <!-- ==================== 日期详情弹窗 ==================== -->
  <view class="popup-mask" wx:if="{{showDetailPopup}}" bindtap="onCloseDetail">
    <view class="popup-content" catchtap="">
      <view class="popup-header">
        <text class="popup-title">{{selectedDate}}</text>
        <text class="popup-close" bindtap="onCloseDetail">✕</text>
      </view>
      <view class="popup-body">
        <block wx:if="{{selectedLessons.length > 0}}">
          <view
            class="lesson-item"
            wx:for="{{selectedLessons}}"
            wx:key="lessonRecordId"
            wx:if="{{item.lessonRecordId}}"
            data-course-id="{{item.courseId}}"
            bindtap="onLessonTap"
          >
            <view class="lesson-status-dot {{item.status}}"></view>
            <view class="lesson-info">
              <text class="lesson-name">{{item.courseName}}</text>
              <text class="lesson-time">{{item.time}} | {{item.deductionType === 'auto' ? '自动消课' : '手动消课'}} ({{item.deductionHours}}课时)</text>
            </view>
          </view>
          <view
            class="lesson-item"
            wx:for="{{selectedLessons}}"
            wx:key="courseId"
            wx:if="{{!item.lessonRecordId}}"
            data-course-id="{{item.courseId}}"
            bindtap="onLessonTap"
          >
            <view class="lesson-status-dot {{item.status}}"></view>
            <view class="lesson-info">
              <text class="lesson-name">{{item.courseName}}</text>
              <text class="lesson-time">{{item.time}} | {{item.status === 'pending' ? '待上课' : '已错过'}}</text>
            </view>
          </view>
        </block>
        <view class="empty-lesson" wx:else>
          <text>当日无课程安排</text>
        </view>
      </view>
    </view>
  </view>

</view>
